    public int? numRows { get; set; }

    public int num = 0;

    public int RandomNum()
    {
        num = random.Next(1, 11);
        return num;
    }

    string btnEvent = "Who cares?";

    void SetButtonEvent()
    {
        btnEvent = DateTime.Now.ToShortDateString();
    }

    private List<char> alphabetSubset = new List<char>();

    void GenerateSubset()
    {
        int size = random.Next(1, 27);
        alphabetSubset.Clear();

