@page "/{numRows:int?}"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

<p>Welcome to your new app.</p>

<Counter Increment="@randomIncrement" />

<p>Generated Increment Value: @randomIncrement</p>

<hr />

<button class="btn btn-primary " @onclick="ShowToday">
    What’s today?
</button>

<p>@todayLabel</p>

<hr />

<button class="btn btn-primary " @onclick="GenerateAlphabet">
    Alphabet
</button>

@if (letters.Count > 0)
{
    <ol>
        @foreach (var letter in letters)
        {
            <li>@letter</li>
        }
    </ol>
}

@code {
    private int randomIncrement;
    private string todayLabel = "Who cares?";
    private List<char> letters = new();

    protected override void OnInitialized()
    {
        randomIncrement = GenerateRandomNumber();
        GenerateRandomTable();
    }

    [Parameter]
    public int? NumRows {get;set;}


    private int GenerateRandomNumber()
    {
        Random rand = new Random();
        randomIncrement = rand.Next(1, 11);
        return randomIncrement;
    }

    void ShowToday()
    {
        todayLabel = DateTime.Today.ToShortDateString();
    }

    private void GenerateAlphabet()
    {
        letters.Clear();

        Random rand = new Random();
        int size = rand.Next(1, 27); 

        for (char c = 'a'; c < 'a' + size; c++)
        {
            letters.Add(c);
        }
    }

    private int[]? numbers;

    private void GenerateRandomTable()
    {
        Random rand = new Random();

        //int quantity = rand.Next(1, 11);
        int num = NumRows ? rand.Next(1, 11):


        numbers = Enumerable.Range(1, num)
                            .Select(x => rand.Next(1, 51)) 
                            .ToArray();
    }
}

<hr />

<h4>Random Numbers (1–50)</h4>

@if (numbers == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table-striped">
        <thead>
            <tr>
                <th>Number</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var num in numbers)
            {
                <tr>
                    <td>@num</td>
                </tr>
            }
        </tbody>
    </table>
}

