        {
            alphabetSubset.Add((char)('a' + i));
        }
    }

    private List<int> randomNumbers = new List<int>();

    protected override void OnInitialized()
    {
        int rows = numRows ?? random.Next(1, 11);

        for (int i = 0; i < rows; i++)
        {
            randomNumbers.Add(random.Next(1, 51));
        }
    }
}

<Counter IncrementAmount="RandomNum()" />

<p>Generated Increment Value: @num</p>

<button style="display: block;" @onclick="SetButtonEvent">
    What's Today?
</button>

